{
    "name": "drewlabs/g-cli",
    "description": "Generates classes, services, models and controller's components or entire project source code from databse structure",
    "type": "library",
    "require-dev": {
        "doctrine/dbal": "^3.0|^4.0",
        "drewlabs/contracts": "^0.4.0",
        "drewlabs/laravel-http": "^0.4.0",
        "drewlabs/laravel-query": "^0.4.0",
        "drewlabs/php-value": "^0.3.0",
        "drewlabs/validation": "^0.4.0",
        "illuminate/console": "^11.41",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/events": "^11.0|^12.0|^13.0",
        "illuminate/queue": "^11.0|^12.0|^13.0",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Drewlabs\\GCli\\": "src/",
            "Drewlabs\\PHPSQLC\\": "src/lib/phpsqlc"
        },
        "files": [
            "./src/proxies.php",
            "./helpers.php"
        ]
    },
    "authors": [
        {
            "name": "azandrew-sidoine",
            "email": "asmyns.platonnas29@gmail.com"
        }
    ],
    "autoload-dev": {
        "classmap": [
            "tests/"
        ],
        "autoload": {
            "psr-4": {
                "Drewlabs\\GCli\\Tests\\": "./tests"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=7.4",
        "drewlabs/code-generator": "^0.3.0",
        "drewlabs/core-helpers": "^0.4.0",
        "drewlabs/htr": "^0.2.0",
        "greenlion/php-sql-parser": "^4.7"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Drewlabs\\GCli\\Plugins\\Laravel\\ServiceProvider"
            ]
        }
    },
    "suggest": {
        "drewlabs/php-value": "required by data transfert objects classes ^0.2.10",
        "drewlabs/laravel-query": "required for eloquent query builder implementation ^0.2.6",
        "drewlabs/laravel-http": "required for laravel http bindings ^0.2.2",
        "drewlabs/validation": "required for validation requirements ^0.2.6",
        "doctrine/dbal": "required for database tables & indexes resolvers ^4.0",
        "symfony/console": "required for using symfony console objects"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
